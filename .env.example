# 邮箱 IMAP 配置
# 复制此文件为 .env 并填入你的实际信息
# .env 文件已被 .gitignore 忽略，不会提交到 Git

# 邮箱地址
EMAIL_USERNAME=your_email@example.com

# IMAP 授权码（非登录密码）
EMAIL_PASSWORD=your_imap_auth_code

# IMAP 服务器（QQ企业邮箱默认 imap.exmail.qq.com）
# IMAP_SERVER=imap.exmail.qq.com
# IMAP_PORT=993

# IMAP 邮箱文件夹（默认 &XeVPXGXlX9c- 即"工作日志"文件夹，如需改用收件箱可设为 INBOX）
# IMAP_MAILBOX=INBOX

# 搜索邮件主题关键词（默认 --工作日志，适配所有用户）
# 如需精确匹配可改为：张三--工作日志
# IMAP_SEARCH_SUBJECT=--工作日志
